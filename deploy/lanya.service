[Unit]
Description=Lanya Flask backend (gunicorn)
After=network.target

[Service]
Type=simple
# 简单起见先用 root；后续硬化可改成专用非 root 用户并 chown /opt/lanya
User=root
WorkingDirectory=/opt/lanya/back
# config.py 会从 back/.env 读环境变量；WorkingDirectory 设为 back 也保证 uploads/ 路径正确
ExecStart=/opt/lanya/back/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
