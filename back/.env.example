# 复制本文件为 back/.env 并填入真实值。
# .env 含明文口令，禁止提交到 git（.gitignore 已忽略）。

# 数据库：填阿里云 RDS 的【内网】地址，不要用公网地址
DB_USER=your_db_user
DB_PASS=your_db_password
DB_HOST=rm-xxxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=lanya

# JWT 签名密钥：用下面命令生成一串随机值填进来，切勿用默认值
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_random_hex_string
